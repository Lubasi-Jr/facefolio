# Copy this file to .env and fill in real values. .env is gitignored; this file is committed.
# Every variable here maps to a field in app/config.py (pydantic-settings).

# --- Database (Supabase Postgres) ---
# Use the Supabase connection string. Note the async driver: postgresql+asyncpg://
# For the app runtime, prefer Supabase's connection POOLER host (port 6543) to avoid
# exhausting direct connections. For Alembic migrations you may use the direct host.
# Find these in Supabase: Project Settings -> Database -> Connection string.
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres

# --- Redis (Upstash, broker only) ---
# Use the TCP/TLS connection string (starts with rediss://), NOT the HTTP/REST URL.
# Find it in Upstash: your database -> "Connect" -> redis-cli / TCP.
REDIS_URL=rediss://default:[YOUR-UPSTASH-PASSWORD]@[YOUR-ENDPOINT].upstash.io:6379

# --- Supabase (Auth + Storage) ---
# Project URL, e.g. https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# The service role key lets the backend generate signed storage URLs and do admin storage ops.
# Supabase: Project Settings -> API -> service_role key. KEEP SERVER-SIDE ONLY. Never ship to the frontend.
SUPABASE_SERVICE_KEY=[YOUR-SERVICE-ROLE-KEY]

# The storage bucket name where event media lives (create it in Supabase Storage).
STORAGE_BUCKET=event-media

# --- CORS ---
# The frontend origin allowed to call this API. Comma-separated if more than one.
# Local dev is the Vite default; add your Vercel URL at deploy time.
FRONTEND_ORIGIN=http://localhost:5173

# --- CV thresholds (start values; calibrate properly in Phase 11) ---
# Cosine similarity above T_HIGH auto-tags; between T_LOW and T_HIGH goes to "Is this you?";
# below T_LOW is ignored. MATCH_MARGIN downgrades a top match when the runner-up is too close.
# These are placeholders — measure genuine vs impostor distributions before trusting them.
MATCH_T_HIGH=0.55
MATCH_T_LOW=0.40
MATCH_MARGIN=0.10

# --- Event limits (free-tier caps) ---
# Reject uploads past the cap; keeps per-event cost bounded.
MAX_PHOTOS_PER_EVENT=500

# --- Celery ---
# Worker concurrency: how many photos process in parallel per worker process.
# Set near your CPU core count for CPU-bound embedding. Keep low locally.
CELERY_CONCURRENCY=2